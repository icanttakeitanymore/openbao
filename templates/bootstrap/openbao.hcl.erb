ui = true

api_addr     = "<%= @schema %>://<%= node['fqdn'] %>:8200"
cluster_addr = "<%= @schema %>://<%= node['fqdn'] %>:8201"

listener "tcp" {
  address         = "0.0.0.0:8200"
  cluster_address = "0.0.0.0:8201"

  <% if @tls_enabled %>
  tls_disable = 0
  tls_cert_file = "/etc/openbao/cert.pem"
  tls_key_file  = "/etc/openbao/key.pem"
  tls_client_ca_file = "/etc/openbao/ca.pem"
  <% else %>
  tls_disable = 1
  <% end %>
}

storage "raft" {
  path = "/opt/openbao/data"

  <% @nodes.each do |n| %>
  retry_join {
    leader_api_addr = "<%= @schema %>://<%= n %>:8200"
  }
  <% end %>
}

plugin_directory = "/etc/openbao/"

log_level  = "info"
log_format = "json"

log_file = "/var/log/openbao/openbao.log"

log_rotate_duration = "24h"

log_rotate_bytes = 104857600  # 100 MB

log_rotate_max_files = 14